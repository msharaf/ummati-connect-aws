{
  "name": "@ummati/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "generate:test": "cross-env DATABASE_URL=file:./test.db prisma generate --schema=./prisma/schema.test.prisma",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:test": "cross-env DATABASE_URL=file:./test.db prisma migrate deploy --schema=./prisma/schema.test.prisma",
    "studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.9.1",
    "cross-env": "^7.0.3",
    "prisma": "^5.22.0",
    "typescript": "^5.3.3"
  },
  "optionalDependencies": {
    "better-sqlite3": "^9.2.2",
    "@types/better-sqlite3": "^7.6.8"
  }
}
