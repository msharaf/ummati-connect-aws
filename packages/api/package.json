{
  "name": "@ummati/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./constants": "./src/constants.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.build.json",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:e2e": "vitest run ../../tests/e2e/api"
  },
  "dependencies": {
    "@clerk/backend": "^1.0.0",
    "@trpc/client": "^10.45.2",
    "@trpc/server": "^10.45.2",
    "@ummati/db": "workspace:*",
    "@ummati/notifications": "workspace:*",
    "dotenv": "^17.2.3",
    "jose": "^6.1.3",
    "superjson": "^2.2.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.9.1",
    "@types/supertest": "^2.0.16",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "eslint": "^8.54.0",
    "jsonwebtoken": "^9.0.2",
    "supertest": "^6.3.3",
    "tsx": "^4.18.0",
    "typescript": "^5.3.3",
    "vitest": "^0.34.6"
  }
}
