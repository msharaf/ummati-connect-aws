{
  "name": "ummati2",
  "private": true,
  "packageManager": "pnpm@8.10.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:e2e:web": "pnpm --filter web test:e2e",
    "test:e2e:mobile": "pnpm --filter mobile test:e2e",
    "test:e2e:api": "pnpm --filter api test:e2e",
    "test:e2e:web:ui": "pnpm --filter web test:e2e:ui",
    "dev:web": "pnpm --filter web dev",
    "dev:mobile": "pnpm --filter mobile start",
    "dev:api": "pnpm --filter api dev",
    "prisma:generate": "pnpm --filter db prisma generate",
    "prisma:generate:test": "pnpm --filter db generate:test"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@vitejs/plugin-react": "^5.1.1",
    "baseline-browser-mapping": "^2.9.18",
    "jsdom": "^27.2.0",
    "turbo": "^1.13.3",
    "typescript": "^5.3.3"
  }
}
