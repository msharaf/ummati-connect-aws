{
  "name": "mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "vitest --passWithNoTests",
    "test:e2e": "detox test",
    "test:e2e:build": "detox build",
    "test:e2e:build:ios": "detox build --configuration ios.sim.debug",
    "test:e2e:build:android": "detox build --configuration android.emu.debug",
    "test:e2e:debug": "detox test --loglevel verbose"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^1.0.0",
    "@clerk/types": "^4.100.0",
    "@expo/vector-icons": "^13.0.0",
    "@react-native-async-storage/async-storage": "^1.18.2",
    "@tanstack/react-query": "^4.36.1",
    "@trpc/client": "^10.45.2",
    "@trpc/react-query": "^10.45.2",
    "@ummati/api": "workspace:*",
    "@ummati/config": "workspace:*",
    "@ummati/db": "workspace:*",
    "date-fns": "^4.1.0",
    "expo": "^49.0.13",
    "expo-constants": "^14.2.1",
    "expo-linear-gradient": "^12.3.0",
    "expo-router": "^3.0.0",
    "expo-secure-store": "^12.3.1",
    "expo-status-bar": "^1.6.0",
    "expo-notifications": "~0.20.1",
    "nativewind": "^2.0.11",
    "react": "18.2.0",
    "react-native": "0.72.6",
    "react-native-gesture-handler": "~2.12.0",
    "react-native-reanimated": "~3.3.0",
    "react-native-safe-area-context": "4.7.1",
    "react-native-svg": "13.9.0",
    "zustand": "^4.4.4"
  },
  "devDependencies": {
    "@babel/core": "^7.23.2",
    "@types/react": "^18.2.38",
    "@types/react-native": "^0.72.7",
    "detox": "^20.14.0",
    "eslint": "^8.54.0",
    "jest-circus": "^29.7.0",
    "typescript": "^5.3.3",
    "vitest": "^0.34.6"
  }
}
